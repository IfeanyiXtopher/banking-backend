[Unit]
Description=SafaPay Bank - Celery worker
After=network.target

[Service]
Type=simple

# Adjust these for your server:
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/banking-backend
EnvironmentFile=/opt/banking-backend/.env

ExecStart=/opt/banking-backend/venv/bin/celery -A config worker -l INFO --concurrency=4

Restart=always
RestartSec=5
KillSignal=SIGTERM
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target

